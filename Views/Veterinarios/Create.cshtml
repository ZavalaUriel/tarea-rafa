@model Veterinaria.Models.VeterinarioModel
@{
    ViewData["Title"] = "Agregar Veterinario";
}

<h2>Agregar Veterinario</h2>

<form asp-action="Create" method="post">
    <div class="form-group mb-3">
        <label asp-for="nombre" class="control-label">Nombre</label>
        <input asp-for="nombre" class="form-control" />
    </div>
    <div class="form-group mb-3">
        <label asp-for="especialidad" class="control-label">Especialidad</label>
        <input asp-for="especialidad" class="form-control" />
    </div>
    <div class="form-group mb-3">
        <label asp-for="telefono" class="control-label">Teléfono</label>
        <input asp-for="telefono" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Guardar</button>
</form>
